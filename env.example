# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here

# MongoDB Configuration (dùng cho docker-compose)
MONGO_USERNAME=admin
MONGO_PASSWORD=password123
MONGO_DATABASE=confession_bot
MONGO_PORT=27017

# Khi chạy bằng Docker, docker-compose tự dựng MONGODB_URI trỏ tới container `mongodb`.
# Chỉ cần khai báo MONGODB_URI nếu chạy bot trực tiếp (npm start) với MongoDB cài sẵn trên máy:
# MONGODB_URI=mongodb://admin:password123@localhost:27017/confession_bot?authSource=admin

# Environment
NODE_ENV=production 