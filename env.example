# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here

# MongoDB Configuration
MONGODB_URI=mongodb://admin:password@localhost:27017/confession_bot?authSource=admin
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password
MONGO_DATABASE=confession_bot

# OpenAI Configuration (Optional - for AI content analysis)
OPENAI_API_KEY=your_openai_api_key_here


# Bot Configuration
NODE_ENV=production
LOG_LEVEL=info

# Test Configuration (Optional)
TEST_GUILD_ID=your_test_guild_id_here
GUILD_ID=your_guild_id_here
CHANNEL_ID=your_channel_id_here 